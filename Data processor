number = int(input("Enter a number (1-10): "))
print(f"\nMultiplication Table for {number}\n")
for i in range(1, 13):
    result = number * i
    print(f"{number} x {i} = {result}")

# list to store temperatures
temperatures = []

# Prompt the user to enter 5 temperatures
for i in range(5):
    temp = float(input("Enter temperature {i + 1}: "))
    temperatures.append(temp)

# calculate highest, lowest, and average temperatures
highest = max(temperatures)
lowest = min(temperatures)
average = sum(temperatures) / len(temperatures)

# Display the results 
print(f"\n--- Temperature Report ---")

print("Temperature entered:", temperatures)
print("highest temperature:", highest)
print("lowest temperature:", lowest)
print("average temperature:", average)

#list of celsius temperatures
celsius_values = [0, 20, 40, 60, 80, 100]

print(f"{'Celsius':<12}{'Fahrenheit':<15}{'Kelvin':<10}")
print("-" * 37)

#loop through values and convert to fahrenheit and kelvin
for celsius in celsius_values:
    fahrenheit = (celsius * 9/5) + 32
    kelvin = celsius + 273.15
    print(f"{celsius:<12}{fahrenheit:<15.2f}{kelvin:<10.2f}")




    
    
