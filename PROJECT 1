def convert_temperature(value, unit):
    """
    Convert temperature between Celsius, Fahrenheit, and Kelvin.
    """
    
    unit = unit.upper()

    if unit == "C":
        fahrenheit = (value * 9 / 5) + 32
        kelvin = value + 273.15
        print(f"{value}°C = {fahrenheit:.2f}°F")
        print(f"{value}°C = {kelvin:.2f} K")

    elif unit == "F":
        celsius = (value - 32) * 5 / 9
        kelvin = celsius + 273.15
        print(f"{value}°F = {celsius:.2f}°C")
        print(f"{value}°F = {kelvin:.2f} K")

    elif unit == "K":
        celsius = value - 273.15
        fahrenheit = (celsius * 9 / 5) + 32
        print(f"{value} K = {celsius:.2f}°C")
        print(f"{value} K = {fahrenheit:.2f}°F")

    else:
        print("Invalid unit. Use C, F, or K.")

