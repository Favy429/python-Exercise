def celsius_to_all(celsius):
    """Convert Celsius to F and K."""
    f = (celsius * 9/5) + 32
    k = celsius + 273.15
    return f, k

def ideal_gas(P, V, n, T):
    """Solve PV=nRT for unknown (pass 0 for unknown)."""
    R = 8.314  # J/(mol*K)
    if P == 0: return (n * R * T) / V
    if V == 0: return (n * R * T) / P
    if n == 0: return (P * V) / (R * T)
    if T == 0: return (P * V) / (n * R)

